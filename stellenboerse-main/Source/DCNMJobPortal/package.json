{
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\" --end-of-line crlf",
    "install:AI_Service": "cd AI_Service && npm install",
    "install:DatabaseHandler": "cd DatabaseHandler && npm install",
    "install:Validation": "cd Validation && npm install",
    "install:WebAgent": "cd WebAgent && npm install",
    "install:SchedulerService": "cd SchedulerService && npm install",
    "install:Frontend": "cd Frontend && npm install",
    "install:ValidationWebsite": "cd ValidationWebsite && npm install",
    "install:all": "npm-run-all -p install:AI_Service install:DatabaseHandler install:Validation install:WebAgent install:Frontend install:ValidationWebsite",
    "watch:AI_Service": "cd AI_Service && npm run watch",
    "watch:DatabaseHandler": "cd DatabaseHandler && npm run watch",
    "watch:Validation": "cd Validation && npm run watch",
    "watch:WebAgent": "cd WebAgent && npm run watch",
    "watch:SchedulerService": "cd SchedulerService && npm run watch",
    "start:Frontend": "cd Frontend && npm run start",
    "start:ValidationWebsite": "cd ValidationWebsite && npm run start",
    "watch:all": "npm-run-all -p watch:DatabaseHandler watch:AI_Service watch:Validation watch:WebAgent start:Frontend start:ValidationWebsite",
    "watch:vis": "npm-run-all -p watch:DatabaseHandler start:Frontend",
    "watch:val": "npm-run-all -p watch:DatabaseHandler start:ValidationWebsite start:Frontend",
    "watch:extraction": "npm-run-all -p watch:DatabaseHandler watch:WebAgent watch:AI_Service"
  },
  "devDependencies": {
    "@eslint/compat": "^1.1.0",
    "@eslint/js": "^9.13.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-promise": "^6.2.0",
    "eslint-plugin-react": "^7.37.1",
    "globals": "^15.11.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.18.0"
  }
}
