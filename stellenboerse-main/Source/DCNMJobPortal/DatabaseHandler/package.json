{
  "name": "databasehandler",
  "version": "1.0.0",
  "main": "databaseServer.js",
  "scripts": {
    "test": "jest --silent --config ./Config/jest.config.ts",
    "start": "ts-node ./databaseServer.ts",
    "watch": "nodemon ./databaseServer.ts",
    "privilege": "ts-node ./Services/privilegeConsole.ts",
    "migration:run": "npx typeorm-ts-node-commonjs migration:run -d ./Config/data-source.ts",
    "migration:revert": "npx typeorm-ts-node-commonjs migration:revert -d ./Config/data-source.ts"
  },
  "description": "databasehandler",
  "dependencies": {
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.0",
    "mysql2": "^3.11.0",
    "random-key": "^0.3.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/axios": "^0.14.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.2",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/yamljs": "^0.2.34",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
